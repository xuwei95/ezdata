# ============================================================================
# ezdata 单文件部署配置 —— 复制为 .env(与 docker-compose.yml 同目录)即可
# ----------------------------------------------------------------------------
# 这一份 .env 同时驱动两层:
#   1) compose 层:镜像 / 宿主端口 / 容器名 / 基础设施容器口令(${VAR} 插值)
#   2) 应用层:backend/worker 通过 env_file 读本文件,其值覆盖镜像内 api/.env.dockermy
#      (compose 注入的环境变量优先级 > 应用 load_dotenv,故这里的值生效)
#
# 用法:
#   - 不建 .env       → 全走镜像/compose 默认值(弱口令 ezdata123456),零配置可直接 up -d
#   - cp .env.example .env,按需取消注释改值 → 改了的覆盖默认,没改的仍用默认
#   - 强随机一键生成:python deploy/gen-secrets.py --env dockermy(生成对齐的 .env 与 api/.env.dockermy)
#
# ⚠️ 三组"跨命名但必须同值"的口令(改一个就要把同组都改成一样,否则应用连不上中间件):
#   · DB:        DB_PASSWORD           (compose 建库口令 + 应用连库口令,同名,改一处即可)
#   · Redis:     REDIS_PASSWORD        (同名,改一处即可)
#   · ES:        ELASTIC_PASSWORD == TASK_ES_PASSWORD == RAG_VECTOR_PASSWORD  (三个要同值)
#   · MinIO:     MINIO_ROOT_USER == S3_ACCESS_KEY,  MINIO_ROOT_PASSWORD == S3_SECRET_KEY
#
# 注意:本文件是 compose env_file 格式(KEY=value,无引号、= 两侧无空格),不要写成 KEY = 'value'。
# 本文件(.env)已 gitignore,勿提交真实密钥。PostgreSQL 部署另见 .env.pg + 镜像内 .env.dockerpg。
# ============================================================================

# ======================= 应用密钥(仅应用层,务必改) =======================
#JWT_SECRET_KEY=<64位hex,token 签名>
#DATA_ENCRYPT_KEY=<Fernet key,库内数据源/AI 凭据加密;留空回退由 JWT 派生>

# ======================= 数据库 =======================
#DB_PASSWORD=ezdata123456          # 同时是 MySQL root 口令 与 应用连库口令(改这一个即可)
#DB_DATABASE=ezdata                # 库名(compose 建库 + 应用连库)
#DB_HOST=ezdata-mysql              # DB 容器名 + 应用连库 host(一般不动)
# 下面这些一般不用设(应用连库走容器内端口 3306;改了反而连不上):
#DB_TYPE=mysql
#DB_USERNAME=root
#DB_PORT=3306                      # 应用→DB 容器内端口,≠ 宿主映射端口(宿主端口见 DB_HOST_PORT)

# ======================= Redis =======================
#REDIS_PASSWORD=ezdata123456       # 容器口令 + 应用连接口令(改这一个即可)
#REDIS_DATABASE=2
#REDIS_HOST=ezdata-redis

# ======================= Elasticsearch(三个同值) =======================
#ELASTIC_PASSWORD=ezdata123456     # ES 容器口令(compose)
#TASK_ES_PASSWORD=ezdata123456     # 应用写任务日志用(=上一个)
#RAG_VECTOR_PASSWORD=ezdata123456  # 应用 RAG 向量库用(=上一个)
#TASK_ES_USERNAME=elastic
#RAG_VECTOR_USER=elastic

# ======================= MinIO / 对象存储(两组同值) =======================
#MINIO_ROOT_USER=minio             # ↕ 与 S3_ACCESS_KEY 同值
#S3_ACCESS_KEY=minio
#MINIO_ROOT_PASSWORD=ezdata123456  # ↕ 与 S3_SECRET_KEY 同值
#S3_SECRET_KEY=ezdata123456
#STORAGE_PUBLIC_ENDPOINT=http://localhost:9000   # 浏览器可达的下载地址前缀(生产改真实域名/IP)

# ======================= 沙箱 / 出网代理 =======================
#SANDBOX_BEARER_KEY=ezdata-sandbox-prod-key       # backend↔sandbox 鉴权(两边由本变量统一)
#SANDBOX_EGRESS_ALLOW=eastmoney.com,sinajs.cn,sina.com.cn,sse.com.cn,szse.cn,cninfo.com.cn,csindex.com.cn,hexun.com,jrj.com.cn,10jqka.com.cn,jin10.com,okx.com,gateio.ws,gate.io,kraken.com,kucoin.com

# ======================= AI 兜底模型 / embedding / rerank(应用层) =======================
#LLM_TYPE=anthropic
#LLM_MODEL=claude-opus-4-8
#LLM_API_KEY=
#LLM_URL=
#LLM_MAX_TOKENS=128000
#EMBEDDING_TYPE=dashscope
#EMBEDDING_MODEL=text-embedding-v2
#DASHSCOPE_API_KEY=
#EMBEDDING_API_KEY=
#RERANK_TYPE=
#RERANK_MODEL=gte-rerank
#RERANK_API_KEY=

# ======================= GitHub SSO(应用层) =======================
#GITHUB_SSO_ENABLED=false
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#GITHUB_REDIRECT_URI=http://localhost/api/oauth/github/callback   # 须与 GitHub OAuth App 一致
#GITHUB_SSO_FRONTEND_URL=http://localhost/sso-callback
#GITHUB_ALLOWED_ORG=
#GITHUB_SSO_AUTO_CREATE=true
#GITHUB_SSO_DEFAULT_ROLE_KEY=common
#GITHUB_SSO_DEFAULT_DEPT_ID=100

# ======================= compose 层:镜像 =======================
#EZDATA_IMAGE=ezdata123/ezdata:2.0.0      # backend / worker / sandbox 共用
#FRONTEND_IMAGE=ezdata123/ezdata_web:2.0.0
#DB_IMAGE=mysql:8.0
#REDIS_IMAGE=redis:latest
#ES_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.13.4
#MINIO_IMAGE=minio/minio
#MINIO_MC_IMAGE=minio/mc

# ======================= compose 层:宿主端口(*_HOST_PORT,与应用连接端口区分) =======================
#FRONTEND_PORT=80
#BACKEND_PORT=19099
#DB_HOST_PORT=13306                # 宿主→DB 映射端口(≠ 应用用的 DB_PORT=3306)
#REDIS_HOST_PORT=16379             # 宿主→Redis 映射端口(≠ 应用用的 6379)
#ES_PORT=9200
#MINIO_PORT=9000
#MINIO_CONSOLE_PORT=19001

# ======================= compose 层:其它 =======================
#ES_JAVA_OPTS=-Xms512m -Xmx512m
#DB_DATA_DIR=/var/lib/mysql        # DB 数据持久化目录(PG 用 /var/lib/postgresql/data)
#DB_DATA_VOLUME=ezdata-db-data
# DB 备份 sidecar(默认在 compose 里注释关闭):
#BACKUP_INTERVAL_SECONDS=86400
#BACKUP_KEEP=7
