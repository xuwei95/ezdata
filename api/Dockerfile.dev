# 后端开发镜像：仅安装 Python 依赖（装进镜像），源码由 compose 挂载，运行时用 uvicorn --reload 热重载
# 说明：改用阿里云 PyPI 源——清华源缺部分包版本（如 mistralai==1.12.0）
FROM python:3.10

# 默认时区=东八区(北京):使容器 date / 日志 / naive datetime.now() 统一走北京时间。
# 不设则回退 UTC(时间戳慢 8 小时)。compose 的 TZ 环境变量仍可覆盖。
ENV TZ=Asia/Shanghai

WORKDIR /app

# 需要完整源码：requirements.txt 末尾的 "." 会把本项目作为包安装（提供 ruoyi CLI）
# 运行时 /app 会被 compose 挂载覆盖，但已安装到 site-packages 的依赖与 CLI 仍保留
COPY . .

RUN pip install --no-cache-dir -r requirements.txt -i https://mirrors.aliyun.com/pypi/simple/
# 数据集成(ETL)依赖：连接器 extract/write 与 DataIntegrationTask 任务运行所需(dlt 等)
RUN pip install --no-cache-dir -r requirements-data.txt -i https://mirrors.aliyun.com/pypi/simple/

EXPOSE 9099

# 启动命令由 docker-compose.dev.yml 覆盖（uvicorn --reload）
