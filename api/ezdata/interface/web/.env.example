# ezdata 轻 UI(interface/web)配置示例。
# 用法:复制为同目录 .env(或 .env.dev),填好后在本目录直接 `python server.py` 即可。
#   cp .env.example .env
# 加载优先级:真实环境变量 > 本目录 .env.dev/.env > api/.env.dev/.env;也可用 EZDATA_ENV_FILE 指定任意路径。

# ================= AI 取数用的 LLM =================
# 暂支持两族:openai(含一切 OpenAI 兼容端点:siliconflow / deepseek / 通义 兼容模式 等)与 anthropic。
LLM_TYPE=siliconflow
LLM_API_KEY=sk-your-key-here
# OpenAI 兼容端点的 base_url;anthropic 用官方端点可留空,自定义网关才填。
LLM_URL=https://api.siliconflow.cn/v1
# 模型编码。推理模型(带 think,如 DeepSeek-V4/R1)首个结果要等几秒;要秒出用 Instruct 类非推理模型。
LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
# 输出上限(取数产物短,给几千即可;anthropic 超大值会触发"必须 streaming")。
LLM_MAX_TOKENS=8192
# true=推理模型,放开推理内容展示;非推理模型填 false(首 token 更快)。
LLM_REASONING=false

# anthropic 示例(取消注释并改上面几项):
# LLM_TYPE=anthropic
# LLM_MODEL=claude-opus-4-8
# LLM_API_KEY=sk-ant-xxxx
# LLM_URL=            # 留空走官方端点;自定义网关才填

# ================= 连接目录(数据源定义) =================
# 存数据源连接的 SQLite 文件路径;不设则默认锚定到 api/ezdata_local.db(与启动目录无关)。
# EZDATA_LOCAL_DB=./ezdata_local.db
